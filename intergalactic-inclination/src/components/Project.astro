---
import "../styles/global.css";
---

 <section class="sec" style="padding-left:0;padding-right:0;padding-bottom:0;">
    <div class="sec-head" style="padding:0 2rem;">
      <span class="sec-title">Selected work</span>
      <div class="sec-line"></div>
    </div>
    <div class="proj-grid">
      <div class="proj-card full" style="animation-delay:0.05s">
        <div class="proj-num">01</div>
        <p class="proj-name">AniMatch</p>
        <p class="proj-desc">Full-stack anime discovery platform. Spring Boot backend consumes the Jikan API, server-rendered UI via Thymeleaf, PostgreSQL with optimized relational data models.</p>
        <div class="proj-tags">
          <span class="proj-tag">Spring Boot</span>
          <span class="proj-tag">PostgreSQL</span>
          <span class="proj-tag">Thymeleaf</span>
          <span class="proj-tag">Jikan API</span>
          <span class="proj-tag">Java</span>
        </div>
        <a class="proj-link" href="https://animatch-ue3t.onrender.com/">View project <i class="ti ti-arrow-right"></i></a>
      </div>
      <div class="proj-card" style="animation-delay:0.1s">
        <div class="proj-num">02</div>
        <p class="proj-name">PvmLogistiek</p>
        <p class="proj-desc">Full site build from scratch. Responsive, fast-loading with custom client features.</p>
        <div class="proj-tags">
          <span class="proj-tag">WordPress</span>
          <span class="proj-tag">PHP</span>
          <span class="proj-tag">Custom theme</span>
        </div>
        <a class="proj-link" href="https://pvmlogistiek.nl/">View site <i class="ti ti-external-link"></i></a>
      </div>
      <div class="proj-card" style="animation-delay:0.15s">
        <div class="proj-num">03</div>
        <p class="proj-name">Alecto Australia</p>
        <p class="proj-desc">Advanced dual-search with FacetWP, custom filtering for recruiter workflows.</p>
        <div class="proj-tags">
          <span class="proj-tag">FacetWP</span>
          <span class="proj-tag">WordPress</span>
          <span class="proj-tag">React</span>
        </div>
        <a class="proj-link" href="https://www.alectoaustralia.com/">View site <i class="ti ti-external-link"></i></a>
      </div>
      <div class="proj-card" style="animation-delay:0.2s">
        <div class="proj-num">04</div>
        <p class="proj-name">Alisondeyette</p>
        <p class="proj-desc">Full theme migration, site-wide content migration, on-page SEO via Yoast.</p>
        <div class="proj-tags">
          <span class="proj-tag">WordPress</span>
          <span class="proj-tag">Yoast SEO</span>
          <span class="proj-tag">Migration</span>
        </div>
        <a class="proj-link" href="https://alisondeyette.com/">View site <i class="ti ti-external-link"></i></a>
      </div>
       <div class="proj-card" style="animation-delay:0.2s">
        <div class="proj-num">05</div>
        <p class="proj-name">Curtismyre</p>
        <p class="proj-desc">Rebuilt and redesigned the entire website with a modern look and improved functionality.</p>
        <div class="proj-tags">
          <span class="proj-tag">WordPress</span>
          <span class="proj-tag">Divi</span>
          <span class="proj-tag">Migration</span>
        </div>
        <a class="proj-link" href="https://curtismyrie.com/">View site <i class="ti ti-external-link"></i></a>
      </div>
       <div class="proj-card" style="animation-delay:0.2s">
        <div class="proj-num">06</div>
        <p class="proj-name">Moorebank Amcal Pharmacy</p>
        <p class="proj-desc">Rebuilt and redesigned sleep apnoea page, integrated forms and modern design.</p>
        <div class="proj-tags">
          <span class="proj-tag">Webflow</span>
          <span class="proj-tag">Responsive</span>
          <span class="proj-tag">Multi-step form</span>
        </div>
        <a class="proj-link" href="https://www.moorebankamcal.com.au/sleep-apnoea">View site <i class="ti ti-external-link"></i></a>
      </div>
    </div>
  </section>