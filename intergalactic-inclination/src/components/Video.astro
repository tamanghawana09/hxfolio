---
import { getVideos } from "../lib/youtube";

const videos = await getVideos();
---

<html lang="en">
  <head>
    <title>My Videos</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
  </head>

  <body>
    <section class="container">
      <header class="header">
        <h1>Latest Videos</h1>
        <p>From my YouTube channel</p>
      </header>

      <div class="grid">
        {
          videos.map((video) => (
            <a
              href={`https://youtube.com/watch?v=${video.id}`}
              target="_blank"
              class="card"
              rel="noopener noreferrer"
            >
              <div class="thumb">
                <img src={video.thumbnail} alt={video.title} loading="lazy" />
              </div>

              <div class="content">
                <h3>{video.title}</h3>

                <div class="meta">
                  <span>
                    {new Date(video.publishedAt).toLocaleDateString()}
                  </span>
                </div>
              </div>
            </a>
          ))
        }
      </div>
    </section>
  </body>
</html>

<style>
/* Global safety for emoji / unicode rendering */
body {
  margin: 0;
  font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
  background: #0b0f19;
  color: #ffffff;
}

/* Layout */
.container {
  max-width: 1100px;
  margin: 0 auto;
  padding: 40px 20px;
}

.header {
  margin-bottom: 30px;
}

.header h1 {
  font-size: 2.2rem;
  margin: 0;
  color: #c9a84c;
}

.header p {
  color: #a1a1aa;
  margin-top: 8px;
}

/* Grid */
.grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  gap: 20px;
}

/* Card */
.card {
  background: #111827;
  border: 1px solid #1f2937;
  border-radius: 14px;
  overflow: hidden;
  text-decoration: none;
  color: inherit;
  transition: transform 0.2s ease, border 0.2s ease;
}

.card:hover {
  transform: translateY(-6px);
  border-color: #f0c96a;
}

/* Thumbnail */
.thumb {
  width: 100%;
  aspect-ratio: 16 / 9;
  overflow: hidden;
  background: #0f172a;
}

.thumb img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

/* Content */
.content {
  padding: 14px;
}

.content h3 {
  font-size: 1rem;
  margin: 0;
  line-height: 1.4;

  /* Fix weird long emoji/title overflow */
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  word-break: break-word;
}

.meta {
  margin-top: 10px;
  font-size: 0.85rem;
  color: #9ca3af;
}
</style>