---
import "../styles/global.css";
---

  <section class="sec">
    <div class="sec-head">
      <span class="sec-title">Experience</span>
      <div class="sec-line"></div>
    </div>
    <div class="exp-row" style="animation-delay:0.05s">
      <div class="exp-left">
        <div class="exp-date">Jul 2026 – present</div>
        <div class="exp-co">Khoja Nepal Pvt Ltd</div>
      </div>
      <div>
        <p class="exp-role">Web Developer & Digital Team Lead</p>
        <ul class="exp-pts">
          <li>Responsible for leading the digital team and managing web development projects</li>
          <li>Collaborating with team members on project planning and execution</li>
        </ul>
      </div>
    </div>
    <div class="exp-row" style="animation-delay:0.05s">
      <div class="exp-left">
        <div class="exp-date">Feb 2026 – Apr 2026</div>
        <div class="exp-co">iSmart</div>
      </div>
      <div>
        <p class="exp-role">Java Developer Intern</p>
        <ul class="exp-pts">
          <li>Implemented scalable services for key projects, including AniMatch and Expense Tracker, utilizing Java Spring Boot.</li>
          <li> Integration of JWT and Oauth protocols for secure user authentication and authorization.</li>
        </ul>
      </div>
    </div>
    <div class="exp-row" style="animation-delay:0.05s">
      <div class="exp-left">
        <div class="exp-date">Jul 2024 – Oct 2025</div>
        <div class="exp-co">WPDrops pvt. ltd</div>
      </div>
      <div>
        <p class="exp-role">Jr WordPress Developer</p>
        <ul class="exp-pts">
          <li>Built custom Gutenberg blocks and plugins using React and Swiper.js</li>
          <li>Full-site builds with advanced block-based features for international clients</li>
        </ul>
      </div>
    </div>
    <div class="exp-row" style="animation-delay:0.12s">
      <div class="exp-left">
        <div class="exp-date">Apr 2024 – Jun 2024</div>
        <div class="exp-co">WPDrops pvt. ltd</div>
      </div>
      <div>
        <p class="exp-role">WordPress Developer Intern</p>
        <ul class="exp-pts">
          <li>Custom meta boxes, CPTs, and WordPress theme customization</li>
          <li>Collaborated with frontend teams on dynamic content integration</li>
        </ul>
      </div>
    </div>
  </section>