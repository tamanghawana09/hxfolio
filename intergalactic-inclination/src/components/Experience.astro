---
import "../styles/global.css";
---

<section class="sec">
  <div class="sec-head">
    <span class="sec-title">Experience</span>
    <div class="sec-line"></div>
  </div>

  <div class="exp-rows">
    <div class="exp-line"></div>
    <div class="exp-line-fill" id="exp-line-fill"></div>

    <div class="exp-row" style="animation-delay:0.05s">
      <span class="exp-dot"></span>
      <div class="exp-left">
        <div class="exp-date">Jul 2026 – present</div>
        <div class="exp-co">Khoja Nepal Pvt Ltd</div>
      </div>
      <div>
        <p class="exp-role">Web Developer & Digital Team Lead</p>
        <ul class="exp-pts">
          <li>Responsible for leading the digital team and managing web development projects</li>
          <li>Collaborating with team members on project planning and execution</li>
        </ul>
      </div>
    </div>

    <div class="exp-row" style="animation-delay:0.05s">
      <span class="exp-dot"></span>
      <div class="exp-left">
        <div class="exp-date">Feb 2026 – Apr 2026</div>
        <div class="exp-co">iSmart</div>
      </div>
      <div>
        <p class="exp-role">Java Developer Intern</p>
        <ul class="exp-pts">
          <li>Implemented scalable services for key projects, including AniMatch and Expense Tracker, utilizing Java Spring Boot.</li>
          <li>Integration of JWT and Oauth protocols for secure user authentication and authorization.</li>
        </ul>
      </div>
    </div>

    <div class="exp-row" style="animation-delay:0.05s">
      <span class="exp-dot"></span>
      <div class="exp-left">
        <div class="exp-date">Jul 2024 – Oct 2025</div>
        <div class="exp-co">WPDrops pvt. ltd</div>
      </div>
      <div>
        <p class="exp-role">Jr WordPress Developer</p>
        <ul class="exp-pts">
          <li>Built custom Gutenberg blocks and plugins using React and Swiper.js</li>
          <li>Full-site builds with advanced block-based features for international clients</li>
        </ul>
      </div>
    </div>

    <div class="exp-row" style="animation-delay:0.12s">
      <span class="exp-dot"></span>
      <div class="exp-left">
        <div class="exp-date">Apr 2024 – Jun 2024</div>
        <div class="exp-co">WPDrops pvt. ltd</div>
      </div>
      <div>
        <p class="exp-role">WordPress Developer Intern</p>
        <ul class="exp-pts">
          <li>Custom meta boxes, CPTs, and WordPress theme customization</li>
          <li>Collaborated with frontend teams on dynamic content integration</li>
        </ul>
      </div>
    </div>
  </div>
</section>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  window.addEventListener("load", () => {
    const wrap = document.querySelector(".exp-rows");
    const fill = document.getElementById("exp-line-fill");
    const rows = gsap.utils.toArray(".exp-row");

    if (!wrap || !fill || rows.length === 0) return;

    // draws the line downward as you scroll through the whole timeline
    gsap.to(fill, {
      scaleY: 1,
      ease: "none",
      scrollTrigger: {
        trigger: wrap,
        start: "top 75%",
        end: "bottom 70%",
        scrub: true,
      },
    });

    // lights up each dot as the line reaches it
    rows.forEach((row) => {
      const dot = row.querySelector(".exp-dot");
      if (!dot) return;

      gsap.to(dot, {
        backgroundColor: "var(--gold, #c9a84c)",
        scale: 1.3,
        duration: 0.3,
        scrollTrigger: {
          trigger: row,
          start: "top 78%",
          toggleActions: "play none none reverse",
        },
      });
    });
  });
</script>

<style>
  .exp-rows {
    position: relative;
  }

  .exp-row {
    position: relative;
    padding-left: 1.75rem; /* room for the line + dots */
  }

  .exp-line,
  .exp-line-fill {
    position: absolute;
    left: 0;
    top: 6px;
    bottom: 6px;
    width: 2px;
  }

  .exp-line {
    background: rgba(255, 255, 255, 0.12); /* swap for your muted line color */
  }

  .exp-line-fill {
    background: var(--gold, #c9a84c); /* swap for your actual accent variable */
    transform: scaleY(0);
    transform-origin: top;
  }

  .exp-dot {
    position: absolute;
    left: 0;
    top: 6px;
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.2);
    transform: translate(calc(-50% + 1px), 0);
  }
</style>